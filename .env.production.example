# ============================================================================
# AI Workbench · 生产环境变量模板
# ----------------------------------------------------------------------------
# 复制为 .env.production 并填入实际值:
#   cp .env.production.example .env.production
#   chmod 600 .env.production
# ----------------------------------------------------------------------------

# === 基础 ===
NODE_ENV=production
PUBLIC_URL=https://ai-workbench.example.com
TAG=latest

# === 镜像 (deploy.sh 自动构建) ===
IMAGE_NAME=ai-workbench/web
REGISTRY=

# === 远程部署 (deploy.sh 使用) ===
REMOTE_HOST=your-server.example.com
REMOTE_USER=deploy
REMOTE_DIR=/opt/ai-workbench
REMOTE_PORT=22
SSH_KEY=~/.ssh/id_ed25519

# === 应用 (运行时注入) ===
# Auth
AUTH_SECRET=change-me-32-chars-min
AUTH_GITHUB_CLIENT_ID=
AUTH_GITHUB_CLIENT_SECRET=
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://user:pass@db:5432/aiworkbench
REDIS_URL=redis://redis:6379

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MINIMAX_API_KEY=

# LLM Observability (L1 iframe 嵌入)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGSMITH_API_KEY=
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Storage
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Analytics
MIXPANEL_TOKEN=
SENTRY_DSN=

# Feature flags
ENABLE_BRAND_ICONS=true
ENABLE_IFRAME_EMBEDS=true
ENABLE_LANGCHAIN_TRACING=true
